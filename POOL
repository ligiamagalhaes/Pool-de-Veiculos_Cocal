        function submitReservation(e, frota) {
            e.preventDefault();
            
            let motivo = document.getElementById('purpose').value;
            if (motivo === 'Outros') {
                motivo = document.getElementById('purposeOutro').value;
            }
            
            const reservation = {
                id: 'RES_' + Date.now(),
                frota: frota,
                usuario: document.getElementById('userName').value,
                email: document.getElementById('userEmail').value,
                diretoria: document.getElementById('userDept').value,
                dataInicio: document.getElementById('startDate').value,
                horaInicio: document.getElementById('startTime').value,
                dataFim: document.getElementById('endDate').value,
                horaFim: document.getElementById('endTime').value,
                motivo: motivo,
                ocupacao: parseInt(document.getElementById('occupancyCount').value),
                notas: document.getElementById('notes').value,
                dataCriacao: new Date().toISOString(),
                status: 'confirmada'
            };

            // ✅ VALIDAR CONFLITOS COM 1H DE INTERVALO
            const novaInicio = new Date(reservation.dataInicio + 'T' + reservation.horaInicio);
            const novaFim = new Date(reservation.dataFim + 'T' + reservation.horaFim);
            const intervalo = 60 * 60 * 1000; // 1 hora em ms
            
            // Buscar todas as reservas ativas para este carro
            const reservasExistentes = allReservations.filter(r => 
                r.frota === frota && r.status !== 'cancelada'
            );
            
            console.log('🔍 Validando: ', reservation.dataInicio, reservation.horaInicio + '-' + reservation.horaFim);
            console.log('📊 Existentes:', reservasExistentes.length);
            
            for (let res of reservasExistentes) {
                const existeInicio = new Date(res.dataInicio + 'T' + res.horaInicio);
                const existeFim = new Date(res.dataFim + 'T' + res.horaFim);
                
                console.log('  vs:', res.dataInicio, res.horaInicio + '-' + res.horaFim);
                
                // ✅ NÃO há conflito se:
                // - Nova termina ANTES que existente começa MENOS 1h
                // - Nova começa DEPOIS que existente termina MAIS 1h
                // Conflito = NÃO (uma das condições acima)
                
                const novaTerminaAntes = novaFim.getTime() <= (existeInicio.getTime() - intervalo);
                const novaComecaDepois = novaInicio.getTime() >= (existeFim.getTime() + intervalo);
                
                const temConflito = !(novaTerminaAntes || novaComecaDepois);
                
                console.log('    Termina antes:', novaTerminaAntes, '| Começa depois:', novaComecaDepois, '| Conflito:', temConflito);
                
                if (temConflito) {
                    const horaDisponivel = adicionarHoras(res.horaFim, 1);
                    showAlert(`❌ CONFLITO DE HORÁRIO!\n\nExiste uma reserva de ${res.horaInicio} a ${res.horaFim}.\n\nCom intervalo obrigatório de 1h, você pode reservar a partir de ${horaDisponivel}.`, 'error');
                    return;
                }
            }

            // Mostrar pop-up ANTES de salvar (mais rápido)
            const vehicle = vehiclesData.find(v => v.frota === frota);
            const start = new Date(reservation.dataInicio + 'T' + reservation.horaInicio);
            const end = new Date(reservation.dataFim + 'T' + reservation.horaFim);
            const hours = Math.round((end - start) / (1000 * 60 * 60) * 10) / 10;
            
            mostrarPopupConfirmacao(reservation, vehicle, hours, start, end);
            
            // Salvar em background (não bloqueia a interface)
            // Salvar localmente primeiro
            allReservations.push(reservation);
            localStorage.setItem('poolReservations', JSON.stringify(allReservations));
            
            // Tentar salvar no Google Sheets em background
            fetch(GOOGLE_SHEETS_URL, {
                method: 'POST',
                body: JSON.stringify(reservation)
            })
            .then(r => r.json())
            .then(result => {
                console.log('Salvo no Google Sheets:', result);
            })
            .catch(e => {
                console.log('Erro ao salvar no Google Sheets:', e);
            });
            
            // Enviar email
            enviarEmail(reservation);
            
            // Atualizar interface
            carregarReservas();
        }
        
        // ✅ Função auxiliar para adicionar horas
        function adicionarHoras(hora, horas) {
            const [h, m] = hora.split(':').map(Number);
            const novaHora = (h + horas) % 24;
            return String(novaHora).padStart(2, '0') + ':' + String(m).padStart(2, '0');
        }

        function enviarEmail(res) {
            const vehicle = vehiclesData.find(v => v.frota === res.frota);
            const start = new Date(res.dataInicio + 'T' + res.horaInicio);
            const end = new Date(res.dataFim + 'T' + res.horaFim);
            const hours = Math.round((end - start) / (1000 * 60 * 60) * 10) / 10;
            
            const msg = `Sua reserva foi confirmada com sucesso!

DETALHES DA RESERVA:
═════════════════════════════════════════════
Veículo: ${vehicle.frota} - ${vehicle.modelo}
Período: ${start.toLocaleDateString('pt-BR')} ${res.horaInicio} até ${end.toLocaleDateString('pt-BR')} ${res.horaFim}
Duração: ${hours} horas
Motivo: ${res.motivo}
Ocupação: ${res.ocupacao} pessoa(s)
Diretoria: ${res.diretoria}
Código da Reserva: ${res.id}

INSTRUÇÕES IMPORTANTES:
═════════════════════════════════════════════
1. Apresente este email na retirada do veículo
2. Verifique o estado do carro (combustível, danos, etc)
3. Anote o km de saída e retorno
4. Devolva no horário agendado: ${res.horaFim}

⚠️ REGRAS DO POOL:
═════════════════════════════════════════════
• Horário: 08:00 às 16:00
• Segunda a Sexta apenas
• Máximo 5 dias consecutivos
• Intervalo de 1h obrigatório entre devoluções`;

            fetch(`https://formspree.io/f/${FORMSPREE_ID}`, {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({
                    email: res.email,
                    message: msg,
                    name: res.usuario,
                    _subject: `✅ Confirmação de Reserva - Veículo ${vehicle.frota}`
                })
            })
            .then(() => {
                mostrarPopupConfirmacao(res, vehicle, hours, start, end);
            })
            .catch(e => {
                mostrarPopupConfirmacao(res, vehicle, hours, start, end);
            });
        }

        function mostrarPopupConfirmacao(res, vehicle, hours, start, end) {
            const popup = document.createElement('div');
            popup.style.cssText = `
                position: fixed;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                background: white;
                padding: 25px;
                border-radius: 15px;
                box-shadow: 0 10px 50px rgba(0,0,0,0.3);
                z-index: 2000;
                max-width: 95%;
                width: 500px;
                max-height: 80vh;
                overflow-y: auto;
                font-family: Arial, sans-serif;
                color: #333;
                border: 3px solid #7A7423;
            `;
            
            popup.innerHTML = `
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                    <h2 style="color: #7A7423; margin: 0; font-size: 22px;">✅ Reserva Confirmada!</h2>
                    <button onclick="fecharPopupConfirmacao()" style="background: #FF5252; color: white; border: none; width: 35px; height: 35px; border-radius: 50%; cursor: pointer; font-size: 20px; font-weight: bold; padding: 0;">×</button>
                </div>
                
                <div style="background: #f5f5f5; padding: 20px; border-radius: 12px; margin-bottom: 20px; font-size: 13px; line-height: 1.6;">
                    <p style="margin: 0 0 10px 0;"><strong style="color: #7A7423;">Veículo:</strong> ${vehicle.frota} - ${vehicle.modelo}</p>
                    <p style="margin: 0 0 10px 0;"><strong style="color: #7A7423;">Período:</strong> ${start.toLocaleDateString('pt-BR')} ${res.horaInicio} até ${end.toLocaleDateString('pt-BR')} ${res.horaFim}</p>
                    <p style="margin: 0 0 10px 0;"><strong style="color: #7A7423;">Duração:</strong> ${hours}h</p>
                    <p style="margin: 0 0 10px 0;"><strong style="color: #7A7423;">Motivo:</strong> ${res.motivo}</p>
                    <p style="margin: 0 0 10px 0;"><strong style="color: #7A7423;">Ocupação:</strong> ${res.ocupacao} pessoa(s)</p>
                    <p style="margin: 0 0 10px 0;"><strong style="color: #7A7423;">Diretoria:</strong> ${res.diretoria}</p>
                    <p style="margin: 0; color: #e74c3c;"><strong>Código:</strong> ${res.id}</p>
                </div>
                
                <div style="background: #fff3cd; padding: 15px; border-radius: 10px; margin-bottom: 15px; border-left: 4px solid #ff9800; font-size: 12px;">
                    <h4 style="color: #ff9800; margin: 0 0 8px 0;">⚠️ INSTRUÇÕES:</h4>
                    <p style="margin: 5px 0;">1. Apresente na retirada</p>
                    <p style="margin: 5px 0;">2. Verifique danos/combustível</p>
                    <p style="margin: 5px 0;">3. Anote km saída/retorno</p>
                    <p style="margin: 5px 0;">4. Devolva às ${res.horaFim}</p>
                </div>
                
                <div style="text-align: center; display: flex; gap: 10px; justify-content: center;">
                    <button onclick="window.print()" style="background: #7A7423; color: white; border: none; padding: 12px 20px; border-radius: 8px; cursor: pointer; font-weight: bold; font-size: 14px;">🖨️ Imprimir</button>
                    <button onclick="fecharPopupConfirmacao()" style="background: #ddd; color: #333; border: none; padding: 12px 20px; border-radius: 8px; cursor: pointer; font-weight: bold; font-size: 14px;">Fechar</button>
                </div>
            `;
            
            const overlay = document.createElement('div');
            overlay.style.cssText = `
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: rgba(0,0,0,0.5);
                z-index: 1999;
                cursor: pointer;
            `;
            overlay.id = 'popupOverlay';
            overlay.onclick = fecharPopupConfirmacao;
            
            document.body.appendChild(overlay);
            document.body.appendChild(popup);
            popup.id = 'popupConfirmacao';
        }

        function fecharPopupConfirmacao() {
            const popup = document.getElementById('popupConfirmacao');
            const overlay = document.getElementById('popupOverlay');
            if (popup) popup.remove();
            if (overlay) overlay.remove();
        }

        function viewReservations(frota) {
            const res = allReservations.filter(r => r.frota === frota && r.status !== 'cancelada');
            const vehicle = vehiclesData.find(v => v.frota === frota);
            document.getElementById('reservasModalTitle').textContent = `Reservas - ${frota}`;
            document.getElementById('reservasContent').innerHTML = res.length === 0 ? '<p>Nenhuma reserva</p>' :
                `<table style="width:100%;font-size:11px;border-collapse:collapse;">
                    <tr style="background:#f0f0f0;"><th style="padding:8px;text-align:left;">Usuário</th><th style="padding:8px;text-align:left;">Data</th><th style="padding:8px;text-align:left;">Horário</th><th style="padding:8px;text-align:left;">Pessoas</th></tr>
                    ${res.map(r => {const s = new Date(r.dataInicio + 'T' + r.horaInicio); const e = new Date(r.dataFim + 'T' + r.horaFim); return `<tr style="border-bottom:1px solid #eee;"><td style="padding:8px;">${r.usuario}</td><td style="padding:8px;">${s.toLocaleDateString('pt-BR')} a ${e.toLocaleDateString('pt-BR')}</td><td style="padding:8px;">${r.horaInicio} - ${r.horaFim}</td><td style="padding:8px;">${r.ocupacao}</td></tr>`;}).join('')}
                </table>`;
            document.getElementById('reservasModal').classList.add('active');
        }

        function abrirGoogleSheets() {
            const sheetUrl = 'https://docs.google.com/spreadsheets/d/1w2yrfNDjKla64F8_4DM03bb-QKGyEnLnl854dvv--I0/edit';
            window.open(sheetUrl, '_blank');
        }

        function mostrarReservados() {
            const filterData = document.getElementById('filterData').value;
            
            if (!filterData) {
                showAlert('Selecione uma data para ver os carros reservados', 'error');
                return;
            }
            
            const checkDate = new Date(filterData + 'T00:00:00');
            const checkDateEnd = new Date(filterData + 'T23:59:59');
            
            let reservados = [];
            
            vehiclesData.forEach(vehicle => {
                const reservations = allReservations.filter(r => r.frota === vehicle.frota && r.status !== 'cancelada');
                
                for (let res of reservations) {
                    const start = new Date(res.dataInicio + 'T' + res.horaInicio);
                    const end = new Date(res.dataFim + 'T' + res.horaFim);
                    
                    // Verifica se o período abrange a data selecionada
                    if (start <= checkDateEnd && end >= checkDate) {
                        reservados.push({
                            frota: vehicle.frota,
                            modelo: vehicle.modelo,
                            usuario: res.usuario,
                            email: res.email,
                            horaInicio: res.horaInicio,
                            horaFim: res.horaFim,
                            dataInicio: res.dataInicio,
                            dataFim: res.dataFim
                        });
                    }
                }
            });
            
            const dataFormatada = new Date(filterData + 'T00:00:00').toLocaleDateString('pt-BR');
            document.getElementById('reservadosContent').innerHTML = reservados.length === 0 ? 
                `<div style="text-align: center; padding: 30px; color: #666;">
                    <p style="font-size: 16px;">✅ Nenhum veículo reservado em ${dataFormatada}</p>
                </div>` :
                `<div style="background: #f9f9f9; padding: 20px; border-radius: 8px;">
                    <p style="margin-top: 0; color: #666;"><strong>Carros reservados em ${dataFormatada}:</strong></p>
                    <div style="overflow-x: auto;">
                        <table style="width:100%;font-size:12px;border-collapse:collapse;">
                            <tr style="background:#f0f0f0;"><th style="padding:10px;text-align:left;border-bottom:1px solid #ddd;">Frota</th><th style="padding:10px;text-align:left;border-bottom:1px solid #ddd;">Modelo</th><th style="padding:10px;text-align:left;border-bottom:1px solid #ddd;">Usuário</th><th style="padding:10px;text-align:left;border-bottom:1px solid #ddd;">Horário</th></tr>
                            ${reservados.map(r => `<tr style="border-bottom:1px solid #eee;"><td style="padding:10px;">${r.frota}</td><td style="padding:10px;">${r.modelo}</td><td style="padding:10px;">${r.usuario}</td><td style="padding:10px;">${r.horaInicio} - ${r.horaFim}</td></tr>`).join('')}
                        </table>
                    </div>
                </div>`;
            
            document.getElementById('reservadosModal').classList.add('active');
        }

        function exportarRelatorio() {
            if (allReservations.length === 0) {showAlert('Nenhuma reserva', 'error'); return;}
            let csv = 'ID,Frota,Usuário,Email,Diretoria,Data Início,Hora Início,Data Fim,Hora Fim,Motivo,Ocupação,Notas,Status\n';
            allReservations.forEach(r => csv += `"${r.id}","${r.frota}","${r.usuario}","${r.email}","${r.diretoria}","${r.dataInicio}","${r.horaInicio}","${r.dataFim}","${r.horaFim}","${r.motivo}","${r.ocupacao}","${r.notas}","${r.status}"\n`);
            const blob = new Blob([csv], {type: 'text/csv'});
            const link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = `relatorio-pool-${new Date().toISOString().split('T')[0]}.csv`;
            link.click();
            showAlert('✅ Relatório exportado!', 'success');
        }

        function closeModal(id) {document.getElementById(id).classList.remove('active');}
        function showAlert(msg, type) {
            const box = document.getElementById('alertBox');
            box.innerHTML = `<div class="alert alert-${type} show">${msg}</div>`;
            setTimeout(() => {box.innerHTML = '';}, 4000);
        }

        function openCancelModal() {
            document.getElementById('cancelModal').classList.add('active');
        }

        function cancelarReserva(e) {
            e.preventDefault();
            
            const resId = document.getElementById('cancelResId').value;
            const resEmail = document.getElementById('cancelResEmail').value;
            const motivo = document.getElementById('cancelMotivo').value;
            
            // Procurar a reserva
            const reserva = allReservations.find(r => r.id === resId && r.email === resEmail);
            
            if (!reserva) {
                const msg = document.getElementById('cancelMsg');
                msg.style.display = 'block';
                msg.style.background = '#f8d7da';
                msg.style.color = '#721c24';
                msg.style.border = '1px solid #f5c6cb';
                msg.innerHTML = '❌ Reserva não encontrada. Verifique o código e email.';
                return;
            }
            
            // Atualizar status no Google Sheets (cancelada)
            const cancelData = {
                id: resId,
                action: 'cancel',
                email: resEmail,
                motivo: motivo,
                dataCancelamento: new Date().toISOString(),
                status: 'cancelada'
            };
            
            fetch(GOOGLE_SHEETS_URL, {
                method: 'POST',
                body: JSON.stringify(cancelData)
            })
            .then(r => r.json())
            .then(result => {
                // Enviar email de cancelamento
                const vehicle = vehiclesData.find(v => v.frota === reserva.frota);
                const msgCancel = `Sua reserva foi CANCELADA com sucesso!\n\nDetalhes:\nVeículo: ${vehicle.frota} - ${vehicle.modelo}\nCódigo: ${resId}\nData cancelamento: ${new Date().toLocaleDateString('pt-BR')}\n\nMotivo: ${motivo}\n\nAtenciosamente,\nPool Veículos Cocal`;
                
                fetch(`https://formspree.io/f/${FORMSPREE_ID}`, {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({email: resEmail, message: msgCancel, name: reserva.usuario, _subject: '❌ Cancelamento de Reserva - ' + vehicle.frota})
                })
                .then(() => {
                    // Atualizar lista local
                    const index = allReservations.findIndex(r => r.id === resId);
                    if (index > -1) {
                        allReservations[index].status = 'cancelada';
                    }
                    
                    showAlert('✅ Reserva cancelada com sucesso! Email enviado para ' + resEmail, 'success');
                    carregarReservas();
                    closeModal('cancelModal');
                    
                    // Limpar campos
                    document.getElementById('cancelResId').value = '';
                    document.getElementById('cancelResEmail').value = '';
                    document.getElementById('cancelMotivo').value = '';
                })
                .catch(e => {
                    showAlert('⚠️ Reserva cancelada mas email pode ter falhado.', 'error');
                    carregarReservas();
                    closeModal('cancelModal');
                });
            })
            .catch(e => {
                const msg = document.getElementById('cancelMsg');
                msg.style.display = 'block';
                msg.style.background = '#f8d7da';
                msg.style.color = '#721c24';
                msg.innerHTML = '❌ Erro ao cancelar: ' + e.message;
            });
        }
        window.onclick = e => {if (e.target.classList && e.target.classList.contains('modal')) e.target.classList.remove('active');};
        initializePage();
    </script>
